# Copy to .env.ads (do not commit .env.ads), fill values, then run:
# set -a; source .env.ads; set +a
# npm run sync:ads-analytics

GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_API_VERSION=v23

# Active now: CZ 5650, SK 8188, HU 9480
# Romania is active from 2026-03-01
GOOGLE_ADS_ACCOUNTS_JSON='[{"market":"cz","customerId":"784-198-5650","accountName":"vyprodej-regalu.cz","currency":"CZK","enabled":true},{"market":"sk","customerId":"257-933-8188","accountName":"vypredaj-regalov.sk","currency":"EUR","enabled":true},{"market":"hu","customerId":"196-153-9480","accountName":"polc-kiarusitas.hu","currency":"HUF","enabled":true},{"market":"sk","customerId":"176-019-1298","accountName":"vypredaj-regalov.sk - starý účet","currency":"EUR","enabled":false},{"market":"ro","customerId":"471-804-3625","accountName":"lichidare-rafturi.ro","currency":"RON","enabled":true,"activeFrom":"2026-03-01"}]'

# Meta Ads / Facebook Marketing API. Use the same read-only token/account IDs
# that the Meta MCP exposes, or paste a long-lived token with ads_read access.
META_GRAPH_API_VERSION=v24.0
META_ACCESS_TOKEN=
META_ADS_ACCOUNTS_JSON='[{"market":"cz","accountId":"act_REPLACE_ME","accountName":"Meta CZ","currency":"CZK","enabled":true},{"market":"sk","accountId":"act_REPLACE_ME","accountName":"Meta SK","currency":"EUR","enabled":true},{"market":"hu","accountId":"act_REPLACE_ME","accountName":"Meta HU","currency":"HUF","enabled":true},{"market":"ro","accountId":"act_REPLACE_ME","accountName":"Meta RO","currency":"RON","enabled":true}]'

# Optional, defaults are used if omitted.
FX_RATES_JSON='{"CZK":1,"EUR":25.2,"HUF":0.063,"RON":5.1}'
SYNC_FROM_DATE=2026-03-01
ADS_SYNC_PROVIDERS=google_ads,meta_ads
GOOGLE_ADS_DETAIL_LEVELS=campaign,device,search_term,shopping_product,asset_group
META_ADS_DETAIL_LEVELS=campaign,adset,ad,audience,geo,placement

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
